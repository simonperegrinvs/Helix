{
  "name": "@helix/server",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/entrypoints/http.ts",
    "dev:mcp": "bun run src/entrypoints/mcp.ts",
    "build": "tsc -p tsconfig.json",
    "start": "bun run dist/entrypoints/http.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "bun test ./src",
    "test:bdd": "cucumber-js --require src/shared/testing/cucumber-hooks.js --require src/shared/testing/steps/**/*.js features/**/*.feature"
  },
  "dependencies": {
    "@helix/contracts": "workspace:*",
    "@helix/shared-kernel": "workspace:*",
    "diff": "^7.0.0",
    "hono": "^4.7.4",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^11.2.0",
    "@types/bun": "latest",
    "@types/diff": "^7.0.1",
    "fast-check": "^3.23.2",
    "typescript": "^5.8.2"
  }
}
